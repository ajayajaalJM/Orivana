# =============================================================================
# Orivana — environment template
# Copy to .env.local for development. Never commit real secrets here.
# =============================================================================

# --- Site URL -----------------------------------------------------------------
# Canonical domain for metadata, OG tags, and OAuth redirect URIs.
# Also used to derive NEXT_PUBLIC_SITE_URL for the demo login fallback.
# Local:      http://localhost:3000
# Production: https://www.orivana.store
NEXT_PUBLIC_SITE_URL=https://www.orivana.store

# Social preview image (optional). Defaults to /og.png in public/.
# NEXT_PUBLIC_OG_IMAGE=/og.png

# --- Shopify Storefront API --------------------------------------------------
# Powers products, collections, Add to Harvest cart, and Shopify Checkout.
# Server-only — never prefix with NEXT_PUBLIC_.
#
# IMPORTANT: Use the Private Storefront API token from the Headless channel
# (Sales channels → Headless → your storefront → Private access token).
# Headless tokens are usually a long hex string, not the Admin API token from Develop apps.
# If checkout redirects to /password, disable Online Store password protection:
# Online Store → Preferences → uncheck "Restrict access to visitors with the password"

# Your Shopify store domain — hostname only, no https:// prefix.
# Example: the-orivana-store.myshopify.com (not https://... and not orivana.store)
SHOPIFY_STORE_DOMAIN=the-orivana-store.myshopify.com

# Headless channel → your storefront → Private Storefront API access token
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# API version — must match Headless channel (e.g. 2024-10)
SHOPIFY_API_VERSION=2024-10

# Homepage featured harvest product handle (must exist in Shopify catalog)
SHOPIFY_FEATURED_PRODUCT_HANDLE=medjool-dates-al-kufra

# --- Shopify Customer Account API --------------------------------------------
# Powers Inner Circle login, profile, and order history (OAuth 2.0 + PKCE).
# Headless channel → Customer Account API → Client ID (Public/Web — no secret)
# Register callback in Headless Application setup:
#   {NEXT_PUBLIC_SITE_URL}/api/customer/account/callback
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# --- Shopify Admin API (optional) --------------------------------------------
# Only needed for B2B membership applications → customer metafields.
# Settings → Apps → Develop apps → Admin API token
# Scopes: read_customers, write_customers, read_customer_metafields, write_customer_metafields
SHOPIFY_ADMIN_ACCESS_TOKEN=

# --- Sanity CMS (embedded Studio at /studio) ---------------------------------
# Editorial content: homepage, journal, recipes, product stories, collections.
# Site runs with built-in mock content when NEXT_PUBLIC_SANITY_PROJECT_ID is unset.
#
# 1. Create project at sanity.io/manage
# 2. Set NEXT_PUBLIC_SANITY_* below (and on Vercel for production)
# 3. CORS origins: http://localhost:3000 + https://orivana.store
# 4. Invite editors in Manage → Members (Editor role)
# 5. Seed once: add SANITY_API_WRITE_TOKEN, then npm run seed:sanity
# 6. Editors open /studio and sign in with their Sanity account

# Public project ID — enables CMS reads and embedded Studio at /studio
NEXT_PUBLIC_SANITY_PROJECT_ID=

# Sanity dataset name (default: production)
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only — Editor API token for npm run seed:sanity (sanity.io/manage → API → Tokens)
# Do not expose to the browser (no NEXT_PUBLIC_ prefix)
SANITY_API_WRITE_TOKEN=

# Server-only — bearer token for POST /api/revalidate when Sanity webhook fires on publish
# Set the same value in Vercel; webhook URL: https://orivana.store/api/revalidate
# Header: Authorization: Bearer <this secret>
SANITY_REVALIDATE_SECRET=

# --- NextAuth (demo fallback) ------------------------------------------------
# Used only when Customer Account API is unavailable (local demo login).
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=generate_a_secure_random_string

# --- Membership (optional) ---------------------------------------------------
# Auto-approve B2B applications without manual review. Use "false" in production.
MEMBERSHIP_AUTO_APPROVE=false
